rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /players/{playerId} {
      allow read: if true;
      allow create, update: if request.resource.data.username is string
        && request.resource.data.username.size() >= 1
        && request.resource.data.username.size() <= 32
        && request.resource.data.foundWords is list
        && request.resource.data.wins is list;
      allow delete: if false;
    }

    match /discoveredWords/{wordDocId} {
      allow read: if true;
      allow create: if !exists(/databases/$(database)/documents/discoveredWords/$(wordDocId))
        && request.resource.data.word is string
        && request.resource.data.username is string
        && request.resource.data.username.size() >= 1
        && request.resource.data.username.size() <= 32
        && request.resource.data.foundAt is number;
      allow update, delete: if false;
    }
  }
}
